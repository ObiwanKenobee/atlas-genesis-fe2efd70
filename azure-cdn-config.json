{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "cdnProfileName": {
      "type": "string",
      "defaultValue": "atlas-genesis-cdn-profile",
      "metadata": {
        "description": "CDN profile name"
      }
    },
    "cdnEndpointName": {
      "type": "string",
      "defaultValue": "atlas-genesis-frontend",
      "metadata": {
        "description": "CDN endpoint name"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "originHostName": {
      "type": "string",
      "metadata": {
        "description": "Origin hostname (App Service URL)"
      }
    },
    "originName": {
      "type": "string",
      "defaultValue": "appservice-origin",
      "metadata": {
        "description": "Origin name"
      }
    }
  },
  "variables": {
    "cdnProfileId": "[resourceId('Microsoft.Cdn/profiles', parameters('cdnProfileName'))]",
    "cdnEndpointId": "[resourceId('Microsoft.Cdn/profiles/endpoints', parameters('cdnProfileName'), parameters('cdnEndpointName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Cdn/profiles",
      "apiVersion": "2021-06-01",
      "name": "[parameters('cdnProfileName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_Microsoft"
      },
      "properties": {
        "profileName": "[parameters('cdnProfileName')]"
      }
    },
    {
      "type": "Microsoft.Cdn/profiles/endpoints",
      "apiVersion": "2021-06-01",
      "name": "[concat(parameters('cdnProfileName'), '/', parameters('cdnEndpointName'))]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles', parameters('cdnProfileName'))]"
      ],
      "sku": {
        "name": "Standard_Microsoft"
      },
      "properties": {
        "isHttpAllowed": true,
        "isHttpsAllowed": true,
        "isCompressionEnabled": true,
        "queryStringCachingBehavior": "IgnoreQueryString",
        "contentTypesToCompress": [
          "text/plain",
          "text/html",
          "text/css",
          "application/x-javascript",
          "application/javascript",
          "application/json",
          "application/xml",
          "application/xml+rss",
          "image/svg+xml"
        ],
        "origins": [
          {
            "name": "[parameters('originName')]",
            "properties": {
              "hostName": "[parameters('originHostName')]",
              "httpPort": 80,
              "httpsPort": 443,
              "originType": "AzureStorage",
              "priority": 1,
              "weight": 1000
            }
          }
        ],
        "originHostHeader": "[parameters('originHostName')]",
        "isOriginHttps": true,
        "defaultOriginGroup": {
          "name": "defaultorigin",
          "properties": {
            "origins": [
              {
                "name": "[parameters('originName')]",
                "properties": {
                  "hostName": "[parameters('originHostName')]",
                  "httpPort": 80,
                  "httpsPort": 443,
                  "originType": "AzureStorage",
                  "priority": 1,
                  "weight": 1000
                }
              }
            ],
            "healthProbeSettings": {
              "probeRequestType": "HEAD",
              "probeProtocol": "Https",
              "probePath": "/",
              "probeIntervalInSeconds": 100
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Cdn/profiles/endpoints/customDomains",
      "apiVersion": "2021-06-01",
      "name": "[concat(parameters('cdnProfileName'), '/', parameters('cdnEndpointName'), '/cdn-custom-domain')]",
      "dependsOn": [
        "[resourceId('Microsoft.Cdn/profiles/endpoints', parameters('cdnProfileName'), parameters('cdnEndpointName'))]"
      ],
      "properties": {
        "hostName": "[concat(parameters('cdnEndpointName'), '.azureedge.net')]"
      }
    }
  ],
  "outputs": {
    "cdnEndpointUrl": {
      "type": "string",
      "value": "[concat('https://', parameters('cdnEndpointName'), '.azureedge.net')]"
    },
    "cdnProfileName": {
      "type": "string",
      "value": "[parameters('cdnProfileName')]"
    }
  }
}