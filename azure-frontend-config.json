{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "webAppName": {
      "type": "string",
      "defaultValue": "atlas-genesis-frontend",
      "metadata": {
        "description": "Name of the Web App"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "appServicePlanName": {
      "type": "string",
      "defaultValue": "atlas-genesis-plan",
      "metadata": {
        "description": "App Service Plan name"
      }
    },
    "appServicePlanSku": {
      "type": "string",
      "defaultValue": "P1v2",
      "allowedValues": [
        "F1",
        "B1",
        "B2",
        "B3",
        "S1",
        "S2",
        "S3",
        "P1v2",
        "P2v2",
        "P3v2"
      ],
      "metadata": {
        "description": "App Service Plan SKU"
      }
    },
    "backendApiUrl": {
      "type": "string",
      "metadata": {
        "description": "Backend API URL"
      }
    },
    "supabaseUrl": {
      "type": "string",
      "metadata": {
        "description": "Supabase URL"
      }
    },
    "supabaseAnonKey": {
      "type": "secureString",
      "metadata": {
        "description": "Supabase anonymous key"
      }
    }
  },
  "variables": {
    "appServicePlanId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-03-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('appServicePlanSku')]",
        "tier": "[parameters('appServicePlanSku')[0]]",
        "size": "[parameters('appServicePlanSku')]",
        "family": "Pv2",
        "capacity": 1
      },
      "kind": "linux",
      "properties": {
        "perSiteScaling": false,
        "elasticScaleEnabled": false,
        "maximumElasticWorkerCount": 1,
        "isSpot": false,
        "isXenon": false,
        "hyperV": false,
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-03-01",
      "name": "[parameters('webAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      ],
      "kind": "app,linux,container",
      "properties": {
        "serverFarmId": "[variables('appServicePlanId')]",
        "siteConfig": {
          "linuxFxVersion": "NODE|18-lts",
          "alwaysOn": true,
          "http20Enabled": true,
          "minTlsVersion": "1.2",
          "ftpsState": "Disabled",
          "cors": {
            "allowedOrigins": [
              "[parameters('backendApiUrl')]"
            ],
            "supportCredentials": false
          },
          "appSettings": [
            {
              "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE",
              "value": "false"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            },
            {
              "name": "VITE_API_URL",
              "value": "[parameters('backendApiUrl')]"
            },
            {
              "name": "VITE_SUPABASE_URL",
              "value": "[parameters('supabaseUrl')]"
            },
            {
              "name": "VITE_SUPABASE_ANON_KEY",
              "value": "[parameters('supabaseAnonKey')]"
            }
          ]
        },
        "httpsOnly": true
      }
    }
  ],
  "outputs": {
    "webAppUrl": {
      "type": "string",
      "value": "[concat('https://', parameters('webAppName'), '.azurewebsites.net')]"
    },
    "webAppName": {
      "type": "string",
      "value": "[parameters('webAppName')]"
    }
  }
}