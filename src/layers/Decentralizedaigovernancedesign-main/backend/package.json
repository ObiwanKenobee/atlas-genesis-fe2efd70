  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.10.9",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/crypto-js": "^4.2.1",
