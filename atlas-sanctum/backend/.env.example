# ═══════════════════════════════════════════════════════════════════════════
# Atlas Sanctum — Integration Layer Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────────────────
ATLAS_ENV=development
ATLAS_REGION=us-east-1
ATLAS_CLUSTER=local
ATLAS_STAGE=dev
ATLAS_SERVICE=atlas-sanctum-api

PORT=3000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atlas_sanctum
DB_USER=postgres
DB_PASSWORD=password

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ── Redis (background jobs, rate limiting) ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Object Storage (S3-compatible) ───────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=atlas-sanctum
S3_REGION=us-east-1

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Email (notifications) ────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@atlas-sanctum.org

# ═══════════════════════════════════════════════════════════════════════════
# AI & AGENTIC CONNECTORS
# ═══════════════════════════════════════════════════════════════════════════

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=
PERPLEXITY_API_KEY=

AI_DEFAULT_PROVIDER=openai
AEGIS_ETHICAL_THRESHOLD=0.8

# Agent Orchestration
AGENT_MAX_CONCURRENT=3

# ═══════════════════════════════════════════════════════════════════════════
# BLOCKCHAIN & WEB3 CONNECTORS
# ═══════════════════════════════════════════════════════════════════════════

ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
COSMOS_RPC_URL=https://rpc.cosmos.network
CHAINLINK_NODE_URL=

# Smart Contract Addresses
IMPACT_VERIFIER_ADDRESS=
COVENANT_REGISTRY_ADDRESS=
RESERVE_VAULT_ADDRESS=
PAYOUT_ROUTER_ADDRESS=

# ═══════════════════════════════════════════════════════════════════════════
# FINTECH & PAYMENTS CONNECTORS
# ═══════════════════════════════════════════════════════════════════════════

STRIPE_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=

# M-Pesa (Kenya)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CALLBACK_URL=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# PayStack (Nigeria)
PAYSTACK_SECRET_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# IOT & EDGE CONNECTORS
# ═══════════════════════════════════════════════════════════════════════════

MQTT_BROKER_URL=mqtt://localhost:1883
LORAWAN_GATEWAY_ID=
EDGE_INFERENCE_ENDPOINT=http://localhost:8000
IOT_SYNC_INTERVAL_MS=30000

# ═══════════════════════════════════════════════════════════════════════════
# OBSERVABILITY & SIEM CONNECTORS
# ═══════════════════════════════════════════════════════════════════════════

DATADOG_API_KEY=
DATADOG_SITE=datadoghq.com

GRAFANA_URL=http://localhost:3000
GRAFANA_TOKEN=

PROMETHEUS_URL=http://localhost:9090

SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════
# EVENT BUS & MESSAGING
# ═══════════════════════════════════════════════════════════════════════════

EVENT_BUS_BACKEND=inprocess
KAFKA_BROKERS=localhost:9092
NATS_URL=nats://localhost:4222
RABBITMQ_URL=amqp://localhost:5672

# ═══════════════════════════════════════════════════════════════════════════
# VECTOR DATABASES
# ═══════════════════════════════════════════════════════════════════════════

PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
WEAVIATE_URL=http://localhost:8080
QDRANT_URL=http://localhost:6333

# ═══════════════════════════════════════════════════════════════════════════
# CLOUD PROVIDERS
# ═══════════════════════════════════════════════════════════════════════════

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# GCP
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY=

# Azure
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# SECRETS MANAGEMENT
# ═══════════════════════════════════════════════════════════════════════════

VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
ENCRYPTION_MASTER_KEY=
