*_override.tf.json

# Kubernetes secrets and sensitive configs
**/kubernetes/secrets/
**/k8s/secrets/
*secret*.yaml
*secret*.yml
!*secret*example*
kubeconfig
kubeconfig.*
.kube/

# Helm values with secrets
values-production.yaml
values-prod.yaml
values-staging.yaml
values-secrets.yaml

# Ansible vault
*.vault
ansible/vault*
group_vars/*/vault*

# SSH
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
known_hosts
authorized_keys

# Docker secrets
docker-compose.override.yml
docker-compose.prod.yml
docker-compose.production.yml
