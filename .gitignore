# =============================================================================
# Atlas Sanctum — .gitignore
#
# Philosophy: Open the stones, protect the cathedral.
# See PHILOSOPHY.md for the full open source model.
#
# OPEN:   Core protocols, APIs, design philosophy, research, governance model
# HIDDEN: Secrets, infrastructure configs, operational intelligence, private data
# =============================================================================


# =============================================================================
# SECRETS & CREDENTIALS — Never commit. Ever.
# =============================================================================

.env
.env.*
!.env.example
!.env.*.example

# Deep nested catch-all — no .env anywhere in the tree
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Key files
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
!*.key.example
!*.pem.example

# Secret stores
.vault-token
vault-secrets/
secrets/
**/secrets/
**/.secrets/
secret.json
secrets.json
credentials.json
service-account*.json
*-service-account.json

# Cloud provider credentials
.aws/credentials
.aws/config
.gcp/
gcp-credentials*.json
azure-credentials*.json
.azure/

# API keys (flat files)
api-keys.txt
api-keys.json
*.apikey

# JWT / signing keys
jwt-secret*
signing-key*
private-key*
public-key*
keypair*


