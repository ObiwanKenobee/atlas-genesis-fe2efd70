{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "downlevelIteration": true,
    "noEmitOnError": false
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "src/core",
    "src/services/ai",
    "src/services/database/databaseFactory.ts",
    "src/services/sso.ts",
    "src/services/mfa.ts",
    "src/services/zeroTrust",
    "src/services/index.ts",
    "src/secretsWatcher.ts"
  ]
}
