# Atlas Genesis — Backend Environment
# IMPORTANT: This file must NOT contain real secrets.
# Set all secrets via environment variables, AWS Secrets Manager, or Doppler.
# See .env.example for documentation of each variable.

NODE_ENV=development
PORT=4000

# Database — set DATABASE_URL or individual vars
# DATABASE_URL=postgres://postgres.<ref>:<password>@pooler.supabase.com:6543/postgres

FRONTEND_URL=http://localhost:8080
ADMIN_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# JWT & Session — MUST be set via environment in production, never hardcoded
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# SESSION_SECRET=
# CSRF_SECRET=

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FROM_EMAIL=noreply@atlas-genesis.local
FROM_NAME=Atlas Genesis

# REDIS_URL=redis://localhost:6379
