# ─── Payments ────────────────────────────────────────────────────────────────
# PAYSTACK_SECRET_KEY=sk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# ─── Redis (optional — sessions fall back to in-memory without this) ─────────
# REDIS_URL=redis://localhost:6379
