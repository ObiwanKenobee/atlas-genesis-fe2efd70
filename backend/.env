# ─── OAuth (optional — email/password works without these) ───────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# ─── Email ───────────────────────────────────────────────────────────────────
# SENDGRID_API_KEY=
