JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=c29563d164c8fc52b51bb668792c73b77bdcad3d74908cca1228c58100e6928a5b2a88f63479cf1c584cfb7b50edf501033421eb0024b394533ffd2cc0ca2e6d
