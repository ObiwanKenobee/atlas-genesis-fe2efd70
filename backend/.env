# Atlas Genesis — Backend Environment
NODE_ENV=development
PORT=4000

# ─── Database ────────────────────────────────────────────────────────────────
# Set DATABASE_URL to enable Postgres. Leave unset to use in-memory mock DB.
# Supabase connection string: Settings → Database → Connection string (URI mode)
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Or individual vars (used when DATABASE_URL is not set):
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=atlas_genesis
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your_password

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080
ADMIN_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# ─── JWT & Session ───────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=6ac9edbc73740d14e725261fcd533acd151fc8180e3eba53615c2092f44f84820808efe2ff3430162f4e2acc908895dff4edde3948b438954aac8e769e13795c
