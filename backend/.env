# Atlas Sanctum — Local Development Environment
# DO NOT commit real credentials. Rotate any secrets that were previously exposed.

NODE_ENV=development
PORT=4000

# Database — uses mock DB when DATABASE_HOST is unset
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=atlas_sanctum
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your_local_db_password

# Frontend
FRONTEND_URL=http://localhost:8080
ADMIN_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_GENERATED_SECRET_run_node_crypto_randomBytes_64
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_GENERATED_SECRET_run_node_crypto_randomBytes_64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session
SESSION_SECRET=REPLACE_WITH_GENERATED_SESSION_SECRET

# CSRF
CSRF_SECRET=REPLACE_WITH_GENERATED_CSRF_SECRET

# OAuth — register apps at console.developers.google.com, github.com/settings/apps, portal.azure.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# Email — use a test account (Mailtrap, Ethereal) for development
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@atlas-sanctum.local
FROM_NAME=Atlas Sanctum

# Payments — use TEST keys only in development
PAYSTACK_SECRET_KEY=sk_test_your_paystack_test_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_test_key
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_key

# Redis — optional, falls back to in-memory if unset
# REDIS_URL=redis://localhost:6379
