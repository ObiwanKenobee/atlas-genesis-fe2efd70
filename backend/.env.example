# ═══════════════════════════════════════════════════════════════
# ATLAS SANCTUM — CIVILIZATIONAL OPERATING SYSTEM
# Environment Configuration Template
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://yourdomain.com
ADMIN_URL=https://admin.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
API_BASE_URL=https://api.yourdomain.com
SERVICE_NAME=atlas-sanctum
SERVICE_VERSION=3.0.0
TENANT_ID=default

# ── Database — PostgreSQL (primary) ──────────────────────────
DATABASE_URL=postgresql://username:password@host:5432/atlas_sanctum
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_SSL=true
READ_REPLICA_URL=postgresql://username:password@replica:5432/atlas_sanctum

# ── Database — Redis ──────────────────────────────────────────
REDIS_URL=redis://:password@redis-host:6379/0
REDIS_CLUSTER_URLS=redis://node1:6379,redis://node2:6379,redis://node3:6379
REDIS_TLS=true

# ── Database — MongoDB (documents / knowledge) ───────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/atlas_sanctum
MONGODB_DB_NAME=atlas_sanctum

# ── Database — Neo4j (knowledge graph) ───────────────────────
NEO4J_URI=bolt://neo4j-host:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=sanctum

# ── Database — ClickHouse (analytics / OLAP) ─────────────────
CLICKHOUSE_HOST=https://clickhouse-host:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-clickhouse-password
CLICKHOUSE_DB=sanctum_analytics

# ── Database — Vector (pgvector / Pinecone / Weaviate) ───────
VECTOR_DB_PROVIDER=pgvector
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east1-gcp
PINECONE_INDEX=sanctum-embeddings
WEAVIATE_HOST=https://weaviate-host:8080
WEAVIATE_API_KEY=your-weaviate-api-key

# ── Database — TimeSeries (InfluxDB / TimescaleDB) ───────────
INFLUXDB_URL=https://influxdb-host:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=atlas-sanctum
INFLUXDB_BUCKET=metrics

# ── Object Storage ────────────────────────────────────────────
S3_BUCKET=atlas-sanctum-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_ENDPOINT=https://s3.amazonaws.com
CDN_URL=https://cdn.yourdomain.com

# ── JWT / Auth ────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secure-access-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=your-super-secure-session-secret-min-64-chars
COOKIE_SECRET=your-super-secure-cookie-signing-secret-min-32-chars
CSRF_SECRET=your-super-secure-csrf-secret-min-32-chars

# ── OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ── Passkeys / WebAuthn ───────────────────────────────────────
WEBAUTHN_RP_NAME=Atlas Sanctum
WEBAUTHN_RP_ID=yourdomain.com
WEBAUTHN_ORIGIN=https://yourdomain.com

# ── ══════════════════════════════════════════════════════════
# INTELLIGENCE PLANE
# ═════════════════════════════════════════════════════════════

# ── LLM Gateway ───────────────────────────────────────────────
LLM_GATEWAY_URL=https://llm-gateway.internal:8080
LLM_DEFAULT_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.1
LLM_REQUEST_TIMEOUT_MS=30000

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORG_ID=your-openai-org-id
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# AWS Bedrock
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Cohere (embeddings / rerank)
COHERE_API_KEY=your-cohere-api-key

# ── AI Memory / Context ───────────────────────────────────────
AI_MEMORY_TTL_SECONDS=86400
AI_CONTEXT_WINDOW_TOKENS=128000
AI_LONG_TERM_MEMORY_ENABLED=true
AI_MEMORY_COMPRESSION_THRESHOLD=50

# ── Ethics Engine ─────────────────────────────────────────────
ETHICS_ENGINE_ENABLED=true
ETHICS_HARD_BLOCK_ON_VIOLATION=true
ETHICS_AUDIT_ALL_DECISIONS=true

# ── ══════════════════════════════════════════════════════════
# TRUST PLANE
# ═════════════════════════════════════════════════════════════

# ── Blockchain ────────────────────────────────────────────────
BLOCKCHAIN_ENABLED=true
ETH_NODE_URL=https://mainnet.infura.io/v3/your-project-id
ETH_WS_URL=wss://mainnet.infura.io/ws/v3/your-project-id
POLYGON_NODE_URL=https://polygon-rpc.com
POLYGON_WS_URL=wss://polygon-rpc.com/ws
BSC_NODE_URL=https://bsc-dataseed.binance.org
CARDANO_NODE_URL=https://cardano-mainnet.blockfrost.io/api/v0
CARDANO_PROJECT_ID=your-blockfrost-project-id
COSMOS_RPC_URL=https://cosmos-rpc.yourdomain.com

# ── Smart Contracts ───────────────────────────────────────────
IDENTITY_REGISTRY_CONTRACT=0x0000000000000000000000000000000000000001
ASSET_REGISTRY_CONTRACT=0x0000000000000000000000000000000000000002
CARBON_CREDIT_CONTRACT=0x0000000000000000000000000000000000000003
TREASURY_CONTRACT=0x0000000000000000000000000000000000000004
GOVERNANCE_DAO_CONTRACT=0x0000000000000000000000000000000000000005
ORACLE_CONTRACT=0x0000000000000000000000000000000000000006
WALLET_PRIVATE_KEY=your-deployer-private-key-never-commit

# ── Oracle Network ────────────────────────────────────────────
CHAINLINK_NODE_URL=https://chainlink-node.yourdomain.com
ORACLE_API_KEY=your-oracle-api-key

# ── Zero Trust ────────────────────────────────────────────────
ZERO_TRUST_ENABLED=true
MTLS_ENABLED=true
DEVICE_TRUST_REQUIRED=false
CONTINUOUS_VERIFICATION_INTERVAL_MS=300000

# ── Key Vault ─────────────────────────────────────────────────
KEY_VAULT_PROVIDER=aws
AWS_KMS_KEY_ID=your-kms-key-id
AZURE_KEYVAULT_URL=https://your-vault.vault.azure.net
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# ── Encryption ────────────────────────────────────────────────
ENCRYPTION_ALGORITHM=AES-256-GCM
ENCRYPTION_MASTER_KEY=your-master-key-base64-encoded-min-32-bytes
POST_QUANTUM_ENABLED=false

# ── ══════════════════════════════════════════════════════════
# VALUE PLANE
# ═════════════════════════════════════════════════════════════

# ── Payments ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_API_SECRET=your-coinbase-api-secret
COINBASE_WEBHOOK_SECRET=your-coinbase-webhook-secret

# ── Treasury ──────────────────────────────────────────────────
TREASURY_RESERVE_THRESHOLD_USD=100000
TREASURY_AUTO_REBALANCE_ENABLED=true
RIU_BASE_PRICE_USD=25.00
RIU_DYNAMIC_PRICING_ENABLED=true

# ── ══════════════════════════════════════════════════════════
# COORDINATION PLANE
# ═════════════════════════════════════════════════════════════

# ── Kafka (event streaming) ───────────────────────────────────
KAFKA_BROKERS=kafka-broker1:9092,kafka-broker2:9092,kafka-broker3:9092
KAFKA_CLIENT_ID=atlas-sanctum
KAFKA_GROUP_ID=sanctum-consumers
KAFKA_SSL_ENABLED=true
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_SASL_USERNAME=your-kafka-username
KAFKA_SASL_PASSWORD=your-kafka-password
KAFKA_SCHEMA_REGISTRY_URL=https://schema-registry:8081

# Topic configuration
KAFKA_TOPIC_EVENTS=sanctum.events
KAFKA_TOPIC_COMMANDS=sanctum.commands
KAFKA_TOPIC_NOTIFICATIONS=sanctum.notifications
KAFKA_TOPIC_AUDIT=sanctum.audit
KAFKA_TOPIC_AI_TASKS=sanctum.ai.tasks
KAFKA_TOPIC_BLOCKCHAIN=sanctum.blockchain
KAFKA_TOPIC_MEASUREMENTS=sanctum.measurements

# ── Workflow Engine ───────────────────────────────────────────
WORKFLOW_ENGINE=temporal
TEMPORAL_HOST=temporal-host:7233
TEMPORAL_NAMESPACE=sanctum
TEMPORAL_TASK_QUEUE=sanctum-workers

# ── Notifications ─────────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Atlas Sanctum
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15550000000
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=your-firebase-private-key

# ── ══════════════════════════════════════════════════════════
# PLANETARY PLANE
# ═════════════════════════════════════════════════════════════

# ── Satellite / Earth Observation ────────────────────────────
SENTINEL_HUB_CLIENT_ID=your-sentinel-hub-client-id
SENTINEL_HUB_CLIENT_SECRET=your-sentinel-hub-client-secret
GOOGLE_EARTH_ENGINE_KEY=your-gee-service-account-key
NASA_EARTHDATA_TOKEN=your-nasa-earthdata-token
COPERNICUS_API_KEY=your-copernicus-api-key

# ── IoT / Sensors ─────────────────────────────────────────────
IOT_BROKER_URL=mqtt://iot-broker:1883
IOT_TLS_ENABLED=true
AWS_IOT_ENDPOINT=your-iot-endpoint.iot.us-east-1.amazonaws.com
GREENGRASS_GROUP_ID=your-greengrass-group-id

# ── Climate / Carbon ──────────────────────────────────────────
CLIMATE_DATA_PROVIDER=copernicus
CARBON_VERIFICATION_ORACLE=https://carbon-oracle.yourdomain.com
NDVI_ANALYSIS_ENABLED=true
SOIL_CARBON_SENSORS_ENABLED=true

# ── ══════════════════════════════════════════════════════════
# OBSERVABILITY
# ═════════════════════════════════════════════════════════════

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/atlas-sanctum/app.log
LOG_FORMAT=json
LOG_MAX_FILES=30d

# ── Tracing (OpenTelemetry) ───────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector:4317
OTEL_SERVICE_NAME=atlas-sanctum-api
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# ── Metrics ───────────────────────────────────────────────────
METRICS_ALLOWED_IPS=127.0.0.1,::1,10.0.0.0/8
METRICS_AUTH_TOKEN=your-metrics-bearer-token

# ── Error Tracking ────────────────────────────────────────────
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── APM ───────────────────────────────────────────────────────
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key

# ── ══════════════════════════════════════════════════════════
# SECURITY
# ═════════════════════════════════════════════════════════════

CORS_ORIGIN=https://yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_STRICT_MAX=10
RATE_LIMIT_BURST_MAX=500

# DDoS / WAF
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# Audit
AUDIT_RETENTION_DAYS=2555
AUDIT_IMMUTABLE_LOG_ENABLED=true

# Compliance
GDPR_ENABLED=true
DATA_RESIDENCY_REGION=eu-west-1
PII_ENCRYPTION_ENABLED=true

# ── ══════════════════════════════════════════════════════════
# MULTI-AGENT PLATFORM
# ═════════════════════════════════════════════════════════════

AGENT_RUNTIME_ENABLED=true
AGENT_MAX_CONCURRENT=50
AGENT_MAX_STEPS=100
AGENT_STEP_TIMEOUT_MS=30000
AGENT_HUMAN_APPROVAL_REQUIRED=true
AGENT_APPROVAL_TIMEOUT_MS=86400000
AGENT_MEMORY_PROVIDER=redis
AGENT_TOOL_TIMEOUT_MS=15000

# ── ══════════════════════════════════════════════════════════
# MULTI-TENANCY
# ═════════════════════════════════════════════════════════════

MAX_TENANTS=10000
DEFAULT_TENANT_PLAN=starter
TENANT_ISOLATION_MODE=row_level_security
ORG_MAX_MEMBERS_FREE=5
ORG_MAX_MEMBERS_ENTERPRISE=unlimited

# ── ══════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═════════════════════════════════════════════════════════════

FEATURE_AI_AGENTS=true
FEATURE_BLOCKCHAIN=true
FEATURE_KAFKA_STREAMING=true
FEATURE_KNOWLEDGE_GRAPH=true
FEATURE_DIGITAL_TWIN=false
FEATURE_POST_QUANTUM_CRYPTO=false
FEATURE_CROSS_CHAIN=false
FEATURE_OFFLINE_SYNC=true
