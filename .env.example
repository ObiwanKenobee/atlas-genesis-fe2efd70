# Atlas Genesis — Frontend Environment
# Copy this file to .env and fill in your values. NEVER commit .env.

# Backend API URL — leave unset in local dev (Vite proxy handles it).
# Set in production, e.g. https://api.atlas-sanctum.earth/api
# Also set BACKEND_URL in Vercel project settings for the vercel.json rewrite.
VITE_API_URL=""
BACKEND_URL="https://your-backend.onrender.com"

VITE_GOOGLE_ANALYTICS_ID=""
VITE_PAYPAL_CLIENT_ID=""
VITE_PAYSTACK_PUBLIC_KEY=""
VITE_STRIPE_PUBLISHABLE_KEY=""
VITE_POSTHOG_KEY=""
VITE_SUPABASE_ANON_KEY=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# Error reporting
VITE_SENTRY_DSN=""
VITE_ERROR_REPORT_ENDPOINT=""

# Blockchain contract addresses (EVM — Ethereum / Polygon / Sepolia)
# Leave blank in dev to disable on-chain features (mock data used instead)
VITE_CONTRACT_RIU_TOKEN=""
VITE_CONTRACT_IMPACT_NFT=""
VITE_CONTRACT_MARKETPLACE=""
VITE_CONTRACT_PAYMENT_TOKEN=""

# Supabase Edge Function secrets (set via `supabase secrets set`)
# STRIPE_SECRET_KEY=sk_live_...
# COINBASE_COMMERCE_API_KEY=...
# PAYSTACK_SECRET_KEY=sk_live_...
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...
# PAYPAL_WEBHOOK_ID=...
