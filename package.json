{
  "name": "atlas-sanctum-fe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "dev:backend": "cd scaffold-mvp/backend && npm run dev",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "deploy:vercel": "npx --yes vercel --prod --confirm",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "setup": "npm install && cd scaffold-mvp/backend && npm install",
    "clean:deps": "python3 delete_node_modules.py && npm install",
    "check:api": "curl -f http://localhost:3001/health || echo 'Backend not running'",
    "lighthouse": "lhci autorun",
    "lighthouse:local": "lhci autorun --config=.lighthouserc.json",
    "lighthouse:ci": "lhci autorun --upload.target=temporary-public-storage",
    "test": "vitest run src/lib/sorting/creditSorters.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "smoke": "node scripts/smoke-routes.mjs",
    "predeploy": "node scripts/pre-deploy.mjs",
    "test:e2e": "playwright test"
  },
  "prepare": "husky install",
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
